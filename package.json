{
  "name": "gemtd",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc -p tsconfig.worker.json && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run --exclude tests/sim-run.test.ts --exclude tests/sim.test.ts",
    "test:watch": "vitest",
    "sim": "npx vitest run tests/sim-run.test.ts",
    "sim:run": "npx tsx tools/sim-compare/cli.ts run",
    "sim:compare": "npx tsx tools/sim-compare/cli.ts compare",
    "sim:history": "npx tsx tools/sim-compare/cli.ts history",
    "telemetry:local": "tsx tools/local-telemetry/server.ts",
    "blueprint:viz": "cd tools/maze_optimizer && uv run python visualize.py",
    "blueprint:export": "cd tools/maze_optimizer && uv run python export_blueprint.py",
    "wave-difficulty": "npx tsx tools/wave-difficulty/cli.ts run",
    "wave-difficulty:compare": "npx tsx tools/wave-difficulty/cli.ts compare",
    "wave-difficulty:history": "npx tsx tools/wave-difficulty/cli.ts history",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "pixi.js": "^8.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "@cloudflare/workers-types": "^4.20260515.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.88.0"
  }
}
