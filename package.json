{
  "name": "gemtd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run --exclude tests/sim-run.test.ts --exclude tests/sim.test.ts",
    "test:watch": "vitest",
    "sim": "npx vitest run tests/sim-run.test.ts",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "pixi.js": "^8.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.88.0"
  }
}
